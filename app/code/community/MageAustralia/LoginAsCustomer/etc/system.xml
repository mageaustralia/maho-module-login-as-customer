<?xml version="1.0"?>
<config>
    <sections>
        <loginascustomer translate="label" module="loginascustomer">
            <label>Login as Customer</label>
            <tab>customer</tab>
            <frontend_type>text</frontend_type>
            <sort_order>400</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>
            <groups>
                <general translate="label">
                    <label>General</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label comment">
                            <label>Enabled</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Master switch for the Login as Customer feature.</comment>
                        </enabled>
                        <token_ttl translate="label comment">
                            <label>Token Lifetime (seconds)</label>
                            <frontend_type>text</frontend_type>
                            <validate>validate-digits</validate>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>How long a one-time login link stays valid. The link is consumed on the immediate redirect, so a short value (e.g. 60) is recommended.</comment>
                        </token_ttl>
                        <show_banner translate="label comment">
                            <label>Show Impersonation Banner</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Display a banner on the storefront while an admin is viewing as a customer.</comment>
                        </show_banner>
                    </fields>
                </general>
            </groups>
        </loginascustomer>
    </sections>
</config>
